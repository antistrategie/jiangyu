<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Root-level NuGet sources. The vendored AssetRipper subtree transitively
    depends on Disarm 2022.1.0-master.99, which is published only on
    SamboyDev's feed (same source AssetRipper's own nuget.config points at).
    NuGet walks up from the project being restored and does not cross into
    sibling directories, so the config inside vendor/AssetRipper/ doesn't
    apply to src/ or tests/ restores — we repeat the source here.
  -->
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="SamboyDev" value="https://nuget.samboy.dev/v3/index.json" />
  </packageSources>
</configuration>
