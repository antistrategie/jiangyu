{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "verbatimModuleSyntax": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "isolatedModules": true,
    "rootDirs": [".", "generated"],
    "paths": {
      "@/*": ["./src/*"],
      // Each alias lists both the source dir and the generated dir so the
      // @css-modules-kit .d.ts files (written under generated/src/) are
      // picked up for aliased CSS imports. `rootDirs` only merges relative
      // paths; it doesn't compose with `paths`, so we enumerate manually.
      "@lib/*": ["./src/lib/*", "./generated/src/lib/*"],
      "@components/*": ["./src/components/*", "./generated/src/components/*"],
    },
    "plugins": [{ "name": "@css-modules-kit/ts-plugin" }],
  },
  "include": ["src"],
  "cmkOptions": {
    "enabled": true,
    "dtsOutDir": "generated",
  },
}
