<Project>

  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <Nullable>disable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>latest</LangVersion>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
  </PropertyGroup>

  <!--
    Game and SDK paths. The defaults assume a standard Steam install; override
    them in local.props (gitignored, written by `jiangyu code sync`). `jiangyu
    compile` injects these from your global config, so a fresh clone compiles
    without running sync first.
  -->
  <PropertyGroup Condition="'$(GameDir)' == '' AND '$(OS)' == 'Unix'">
    <GameDir>$(HOME)/.local/share/Steam/steamapps/common/Menace</GameDir>
  </PropertyGroup>
  <PropertyGroup Condition="'$(GameDir)' == '' AND '$(OS)' == 'Windows_NT'">
    <GameDir>C:\Program Files (x86)\Steam\steamapps\common\Menace</GameDir>
  </PropertyGroup>

  <PropertyGroup>
    <MelonLoaderDir Condition="'$(MelonLoaderDir)' == ''">$(GameDir)/MelonLoader/net6</MelonLoaderDir>
    <GameAssembliesDir Condition="'$(GameAssembliesDir)' == ''">$(GameDir)/MelonLoader/Il2CppAssemblies</GameAssembliesDir>
  </PropertyGroup>

  <!--
    Dev-only sources. Files named *.Dev.cs (e.g. dev verbs, debug probes) compile only in a dev
    build. A plain `jiangyu compile` sets JiangyuDev=true (dev verbs in, for local testing). A
    release compile and `jiangyu package` leave it unset, and Directory.Build.targets then excludes
    the *.Dev.cs sources, so they are stripped from the shipped DLL. JIANGYU_DEV is defined here too,
    for #if guards in shared files.
  -->
  <PropertyGroup Condition="'$(JiangyuDev)' == 'true'">
    <DefineConstants>$(DefineConstants);JIANGYU_DEV</DefineConstants>
  </PropertyGroup>

  <Import Project="local.props" Condition="Exists('local.props')" />

</Project>
